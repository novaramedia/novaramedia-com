.spinner
  width: 1em
  height: 1em
  margin: 0 auto
  position: relative

.double-bounce1, .double-bounce2
  width: 100%
  height: 100%
  border-radius: 50%
  background-color: var(--color-black-soft)
  opacity: 0.6
  position: absolute
  top: 0
  left: 0
  animation: sk-bounce 2.0s infinite ease-in-out

.spinner--white
  .double-bounce1, .double-bounce2
    background-color: var(--color-white-soft)

.double-bounce2
  animation-delay: -1.0s

@keyframes sk-bounce
  0%, 100%
    transform: scale(0.0)
  50%
    transform: scale(1.0)
