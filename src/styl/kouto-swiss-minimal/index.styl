// Media Query Utilities
// ============================================================================

ks-min-screen( width )
    @media screen and ( min-width: width )
        {block}

ks-max-screen( width )
    @media screen and ( max-width: width )
        {block}

ks-screen( min-width, max-width = null )
    if max-width
        @media screen and ( min-width: min-width ) and ( max-width: max-width )
            {block}
    else
        @media screen and ( min-width: min-width )
            {block}

unless ks-no-conflict
    min-screen = ks-min-screen
    max-screen = ks-max-screen
    screen = ks-screen

// Retina Query
// ============================================================================

ks-retina()
    @media only screen and ( -webkit-min-device-pixel-ratio: 2 ), only screen and ( min-device-pixel-ratio: 2 )
        {block}

retina = ks-retina unless ks-no-conflict

// Retina Image
// ============================================================================

ks-retina-image( file, width, height, extension = "png" )
    background-image: url( file + "." + extension )
    ks-retina()
        background-image: url( file + "@2x." + extension )
        background-size: width height

retina-image = ks-retina-image unless ks-no-conflict
